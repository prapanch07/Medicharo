# Copy to .env.local and fill with your Firebase web config values.
# Values are public (Firebase web API keys are public by design);
# this file lets you swap projects (staging/prod) without code changes.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
